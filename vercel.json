{
  "buildCommand": "cd new-frontend && npm install && npm run build",
  "outputDirectory": "new-frontend/dist",
  "installCommand": "cd new-frontend && npm install",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://your-backend-url.com/api/:path*"
    }
  ]
}
